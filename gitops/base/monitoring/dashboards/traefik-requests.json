{
 "title": "Traefik \u2014 Requests & Latency",
 "uid": "traefik-requests",
 "schemaVersion": 39,
 "version": 1,
 "refresh": "30s",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "timezone": "",
 "templating": {
  "list": []
 },
 "panels": [
  {
   "type": "stat",
   "title": "Total req/s",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 0,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum(rate(traefik_entrypoint_requests_total[5m]))",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "stat",
   "title": "4xx req/s",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
