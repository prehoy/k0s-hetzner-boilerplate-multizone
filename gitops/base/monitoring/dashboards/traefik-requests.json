  {
   "type": "stat",
   "title": "Avg req duration",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 16,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
