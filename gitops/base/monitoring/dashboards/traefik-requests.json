     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (service)(rate(traefik_service_requests_total{code=~\"5..\"}[5m]))",
     "legendFormat": "{{service}}"
    }
   ]
  },
  {
   "type": "table",
   "title": "Top 5xx apps now (req/s, instant)",
   "datasource": {
