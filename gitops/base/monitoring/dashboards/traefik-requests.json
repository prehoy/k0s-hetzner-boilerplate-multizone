    ]
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "topk(20, sum by (service)(rate(traefik_service_requests_total{code=~\"5..\"}[5m])) > 0)",
     "format": "table",
     "instant": true
    }
