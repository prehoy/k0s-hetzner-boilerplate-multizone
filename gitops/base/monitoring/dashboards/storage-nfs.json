{
 "title": "Storage \u2014 Disk, NFS & Volumes",
 "uid": "storage-nfs",
 "schemaVersion": 39,
 "version": 1,
 "refresh": "30s",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "timezone": "",
 "templating": {
  "list": []
 },
 "panels": [
  {
   "type": "stat",
   "title": "Min root fs free %",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 0,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "yellow",
        "value": 10
       },
       {
        "color": "green",
        "value": 20
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "min(node_filesystem_avail_bytes{mountpoint=\"/\"}/node_filesystem_size_bytes{mountpoint=\"/\"})*100",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "stat",
   "title": "NFS /shared free",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 4,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes",
     "color": {
      "mode": "thresholds"
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "min(node_filesystem_avail_bytes{fstype=~\"nfs.*\"})",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "stat",
   "title": "NFS /shared used %",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 9,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 75
       },
       {
        "color": "red",
        "value": 90
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "max((1-node_filesystem_avail_bytes{fstype=~\"nfs.*\"}/node_filesystem_size_bytes{fstype=~\"nfs.*\"})*100)",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "stat",
   "title": "Total PV capacity",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 14,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes",
     "color": {
      "mode": "thresholds"
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum(kube_persistentvolume_capacity_bytes)",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "stat",
   "title": "PVCs bound",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 19,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "color": {
      "mode": "thresholds"
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area"
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum(kube_persistentvolumeclaim_status_phase{phase=\"Bound\"})",
     "legendFormat": ""
    }
   ]
  },
  {
   "type": "gauge",
   "title": "Root fs used % by node",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 5
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "min": 0,
     "max": 100,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 75
       },
       {
        "color": "red",
        "value": 90
       }
      ]
     }
    }
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "(1-node_filesystem_avail_bytes{mountpoint=\"/\"}/node_filesystem_size_bytes{mountpoint=\"/\"})*100",
     "legendFormat": "{{instance}}"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Filesystem available by node:mount",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 5
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes",
     "custom": {
      "fillOpacity": 10,
      "showPoints": "never",
      "stacking": {
       "mode": "none"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "last",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|shm|ramfs\"}",
     "legendFormat": "{{instance}}:{{mountpoint}}"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "NFS /shared: used vs size",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 13
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes",
     "custom": {
      "fillOpacity": 10,
      "showPoints": "never",
      "stacking": {
       "mode": "none"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "last",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "node_filesystem_size_bytes{fstype=~\"nfs.*\"}-node_filesystem_avail_bytes{fstype=~\"nfs.*\"}",
     "legendFormat": "used"
    },
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "node_filesystem_size_bytes{fstype=~\"nfs.*\"}",
     "legendFormat": "size"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Disk read/write throughput by node",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 13
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "custom": {
      "fillOpacity": 10,
      "showPoints": "never",
      "stacking": {
       "mode": "none"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "last",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (instance)(rate(node_disk_read_bytes_total[5m]))",
     "legendFormat": "{{instance}} read"
    },
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (instance)(rate(node_disk_written_bytes_total[5m]))",
     "legendFormat": "{{instance}} write"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Inode usage % by node:mount",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 21
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "custom": {
      "fillOpacity": 10,
      "showPoints": "never",
      "stacking": {
       "mode": "none"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "last",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "(1-node_filesystem_files_free{fstype!~\"tmpfs|overlay\"}/node_filesystem_files{fstype!~\"tmpfs|overlay\"})*100",
     "legendFormat": "{{instance}}:{{mountpoint}}"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Network throughput by node",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 21
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "custom": {
      "fillOpacity": 10,
      "showPoints": "never",
      "stacking": {
       "mode": "none"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "last",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (instance)(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|tunl.*|vxlan.*\"}[5m]))",
     "legendFormat": "{{instance}} rx"
    },
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (instance)(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cali.*|tunl.*|vxlan.*\"}[5m]))",
     "legendFormat": "{{instance}} tx"
    }
   ]
  },
  {
   "type": "table",
   "title": "PVC usage (requested)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 9,
    "w": 24,
    "x": 0,
    "y": 29
   },
   "options": {
    "showHeader": true
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sort_desc(sum by (namespace,persistentvolumeclaim)(kube_persistentvolumeclaim_resource_requests_storage_bytes))",
     "format": "table",
     "instant": true
    }
   ]
  }
 ]
}