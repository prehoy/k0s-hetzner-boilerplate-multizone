   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum(pg_stat_database_numbackends)/max(pg_settings_max_connections)*100",
     "legendFormat": ""
    }
   ]
  },
