   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (namespace,pod)(rate(kube_pod_container_status_restarts_total[15m]))>0",
     "legendFormat": "{{namespace}}/{{pod}}"
    }
