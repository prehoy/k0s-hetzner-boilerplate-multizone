{
  "uid": "cluster-heat",
  "title": "Heat Situation — cluster CPU/RAM pressure",
  "tags": ["cluster", "heat", "capacity", "cpu"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "gauge", "title": "Cluster CPU utilization %",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 95 } ] } } },
      "targets": [ { "refId": "A", "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))" } ]
    },
    {
      "type": "gauge", "title": "Cluster RAM utilization %",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 95 } ] } } },
      "targets": [ { "refId": "A", "expr": "100 * sum(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes)" } ]
    },
    {
      "type": "stat", "title": "Hottest node — CPU %",
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 100 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "targets": [ { "refId": "A", "instant": true, "expr": "topk(1, 100 * (1 - avg by (node)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))))", "legendFormat": "{{node}}" } ]
    },
    {
      "type": "stat", "title": "Hottest node — RAM %",
      "gridPos": { "h": 5, "w": 4, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 92 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "targets": [ { "refId": "A", "instant": true, "expr": "topk(1, 100 * (1 - sum by (node)(node_memory_MemAvailable_bytes) / sum by (node)(node_memory_MemTotal_bytes)))", "legendFormat": "{{node}}" } ]
    },
    {
      "type": "stat", "title": "Pressure",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "red", "value": 1 } ] } }, "overrides": [ { "matcher": { "id": "byName", "options": "nodes" }, "properties": [ { "id": "thresholds", "value": { "steps": [ { "color": "green", "value": 0 } ] } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } } ] } ] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "orientation": "horizontal" },
      "targets": [
        { "refId": "A", "instant": true, "expr": "count(kube_node_info)", "legendFormat": "nodes" },
        { "refId": "B", "instant": true, "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"} == 0) or vector(0)", "legendFormat": "NotReady" },
        { "refId": "C", "instant": true, "expr": "count(kube_pod_status_phase{phase=\"Pending\"} == 1) or vector(0)", "legendFormat": "pending pods" },
        { "refId": "D", "instant": true, "expr": "count(max by (namespace,pod)(kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\"}) == 1) or vector(0)", "legendFormat": "OOMKilled pods" }
      ]
    },

    {
      "type": "bargauge", "title": "Per-node CPU % (the heat map)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 100 } ] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "instant": true, "expr": "sort_desc(100 * (1 - avg by (node)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))))", "legendFormat": "{{node}}" } ]
    },
    {
      "type": "bargauge", "title": "Per-node RAM %",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 92 } ] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "instant": true, "expr": "sort_desc(100 * (1 - sum by (node)(node_memory_MemAvailable_bytes) / sum by (node)(node_memory_MemTotal_bytes)))", "legendFormat": "{{node}}" } ]
    },

    {
      "type": "bargauge", "title": "Load average per core (>1 = CPU-saturated)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "min": 0, "max": 2, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 1.5 } ] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "instant": true, "expr": "sort_desc(max by (node)(node_load1) / count by (node)(node_cpu_seconds_total{mode=\"idle\"}))", "legendFormat": "{{node}}" } ]
    },
    {
      "type": "table", "title": "Top 10 CPU-throttled workloads (the actual pain)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "displayMode": "gradient-gauge" }, "max": 1 } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Value", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(10, sum by (namespace, pod)(rate(container_cpu_cfs_throttled_periods_total{container!=\"\"}[5m])) / clamp_min(sum by (namespace, pod)(rate(container_cpu_cfs_periods_total{container!=\"\"}[5m])), 1))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "throttled fraction" } } } ]
    },

    {
      "type": "timeseries", "title": "CPU % per node over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 8 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "targets": [ { "refId": "A", "expr": "100 * (1 - avg by (node)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))", "legendFormat": "{{node}}" } ]
    },
    {
      "type": "timeseries", "title": "RAM % per node over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 8 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "targets": [ { "refId": "A", "expr": "100 * (1 - sum by (node)(node_memory_MemAvailable_bytes) / sum by (node)(node_memory_MemTotal_bytes))", "legendFormat": "{{node}}" } ]
    },

    {
      "type": "table", "title": "Top 12 pods by CPU (cores)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "custom": { "displayMode": "gradient-gauge" } } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Value", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(12, sum by (namespace, pod)(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "cpu cores" } } } ]
    },
    {
      "type": "timeseries", "title": "Burst pool size (cas-pool) — heat relief / cost",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "fillOpacity": 20, "stepInterval": "1m" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "count(kube_node_info)", "legendFormat": "total nodes" },
        { "refId": "B", "expr": "count(kube_node_role{role=\"burst\"}) or count(kube_node_labels{label_node_pool=\"burst\"}) or vector(0)", "legendFormat": "burst nodes" }
      ]
    },

    {
      "type": "row", "title": "Right-sizing — requests vs real usage (catch over/under-registered)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },
    {
      "type": "stat", "title": "CPU — requested vs real (cores)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "orientation": "horizontal" },
      "targets": [
        { "refId": "A", "expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\"})", "legendFormat": "requested" },
        { "refId": "B", "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m]))", "legendFormat": "real" }
      ]
    },
    {
      "type": "stat", "title": "Memory — requested vs real",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "orientation": "horizontal" },
      "targets": [
        { "refId": "A", "expr": "sum(kube_pod_container_resource_requests{resource=\"memory\"})", "legendFormat": "requested" },
        { "refId": "B", "expr": "sum(container_memory_working_set_bytes{container!=\"\"})", "legendFormat": "real" }
      ]
    },
    {
      "type": "stat", "title": "Reserved but idle (reclaimable headroom)",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "CPU cores idle" }, "properties": [ { "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 } ] }, { "matcher": { "id": "byName", "options": "RAM idle" }, "properties": [ { "id": "unit", "value": "bytes" } ] } ] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "orientation": "horizontal" },
      "targets": [
        { "refId": "A", "expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\"}) - sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m]))", "legendFormat": "CPU cores idle" },
        { "refId": "B", "expr": "sum(kube_pod_container_resource_requests{resource=\"memory\"}) - sum(container_memory_working_set_bytes{container!=\"\"})", "legendFormat": "RAM idle" }
      ]
    },

    {
      "type": "table", "title": "Memory OVER-registered (reclaim: request − real, desc)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "displayMode": "gradient-gauge" } } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "wasted", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(15, sum by (namespace, pod)(kube_pod_container_resource_requests{resource=\"memory\"}) - sum by (namespace, pod)(container_memory_working_set_bytes{container!=\"\"}))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "wasted" } } } ]
    },
    {
      "type": "table", "title": "Memory UNDER-registered / OOM risk (real ÷ limit, desc)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "displayMode": "gradient-gauge" }, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 0.8 }, { "color": "red", "value": 0.9 } ] } } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "real/limit", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(15, sum by (namespace, pod)(container_memory_working_set_bytes{container!=\"\"}) / sum by (namespace, pod)(kube_pod_container_resource_limits{resource=\"memory\"}))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "real/limit" } } } ]
    },

    {
      "type": "table", "title": "CPU OVER-registered (reclaim: request − real cores, desc)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3, "custom": { "displayMode": "gradient-gauge" } } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "idle cores", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(15, sum by (namespace, pod)(kube_pod_container_resource_requests{resource=\"cpu\"}) - sum by (namespace, pod)(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "idle cores" } } } ]
    },
    {
      "type": "table", "title": "CPU UNDER-registered (real ÷ request, >1 = throttles under pressure)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "custom": { "displayMode": "gradient-gauge" }, "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 } ] } } },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "real/request", "desc": true } ] },
      "targets": [ { "refId": "A", "instant": true, "format": "table", "expr": "topk(15, sum by (namespace, pod)(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) / clamp_min(sum by (namespace, pod)(kube_pod_container_resource_requests{resource=\"cpu\"}), 0.001))" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "real/request" } } } ]
    }
  ]
}
