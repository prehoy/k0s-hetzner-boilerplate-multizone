        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Translations over time",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "time_series",
          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), count(*) AS translations FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Characters by engine",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "time_series",
          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), sum(CASE WHEN e='google' THEN c END) AS google, sum(CASE WHEN e='deepl' THEN c END) AS deepl, sum(CASE WHEN e='azure' THEN c END) AS azure FROM (  SELECT \"createdAt\", characters c, 'google' e FROM \"GOOGLEUsage\" WHERE $__timeFilter(\"createdAt\")  UNION ALL SELECT \"createdAt\", characters, 'deepl' FROM \"DEEPLUsage\" WHERE $__timeFilter(\"createdAt\")  UNION ALL SELECT \"createdAt\", characters, 'azure' FROM \"AZUREUsage\" WHERE $__timeFilter(\"createdAt\")) s GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "End-to-end translation time (avg & p95)",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "time_series",
          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), round(avg(\"time\")) AS avg_ms, round(percentile_cont(0.95) WITHIN GROUP (ORDER BY \"time\")) AS p95_ms FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {},
      "id": 8
    },
    {
      "type": "timeseries",
      "title": "Latency stages (avg ms)",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "time_series",
          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), round(avg(\"queueWait\")) AS queue_wait, round(avg(\"detectionTime\")) AS detect, round(avg(\"translationTime\")) AS translate, round(avg(\"time\")) AS end_to_end FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {},
      "id": 9
    },
    {
