        "x": 0,
        "y": 0
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Translations",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "table",
          "editorMode": "code",
          "rawSql": "SELECT count(*) AS v FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Characters translated",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "table",
          "editorMode": "code",
          "rawSql": "SELECT (SELECT coalesce(sum(characters),0) FROM \"GOOGLEUsage\" WHERE $__timeFilter(\"createdAt\"))+(SELECT coalesce(sum(characters),0) FROM \"DEEPLUsage\" WHERE $__timeFilter(\"createdAt\"))+(SELECT coalesce(sum(characters),0) FROM \"AZUREUsage\" WHERE $__timeFilter(\"createdAt\")) AS v"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Cache hit rate",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "table",
          "editorMode": "code",
          "rawSql": "SELECT round(100.0*avg((\"cached\")::int),1) AS v FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "id": 4
    },
    {
      "type": "stat",
      "title": "Avg end-to-end translation",
      "datasource": {
        "type": "postgres",
        "uid": "pg-lang-processing"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "pg-lang-processing"
          },
          "format": "table",
          "editorMode": "code",
          "rawSql": "SELECT round(avg(\"time\")) AS v FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\")"
