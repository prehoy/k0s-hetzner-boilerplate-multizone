      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "${app}"
          },
          "format": "table",
          "editorMode": "code",
          "rawSql": "SELECT \"sourceLanguage\"||' -> '||\"targetLanguage\" AS pair, count(*) AS translations, sum(characters) AS characters, round(avg(\"time\")) AS avg_ms, round(100.0*avg((\"cached\")::int),1) AS cache_pct FROM \"UsageLog\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 2 DESC LIMIT 20"
