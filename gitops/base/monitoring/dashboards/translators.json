          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), round(avg(\"time\")) AS avg_end_to_end, round(percentile_cont(0.95) WITHIN GROUP (ORDER BY \"time\")) AS p95_end_to_end, round(avg(\"queueTime\")) AS queue FROM \"UsageLog\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
