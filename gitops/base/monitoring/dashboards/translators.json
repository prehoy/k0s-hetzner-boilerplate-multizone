          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), sum(\"inputTokens\") AS input_tokens, sum(\"outputTokens\") AS output_tokens FROM \"OpenAIUsage\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
