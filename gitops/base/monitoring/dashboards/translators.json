          "format": "time_series",
          "editorMode": "code",
          "rawSql": "SELECT $__timeGroupAlias(\"createdAt\", $__interval), round(100.0*avg((\"cached\")::int),1) AS cache_hit_pct FROM \"QueueStats\" WHERE $__timeFilter(\"createdAt\") GROUP BY 1 ORDER BY 1"
