apiVersion: k0s.k0sproject.io/v1beta1
kind: ClusterConfig
metadata:
  name: k0s
spec:
  api:
    address: {{internal_ip}}
    k0sApiPort: 9443
    port: 6443
    # Apiserver egress goes DIRECT (not konnectivity): controllers run --enable-worker on the Calico
    # pod network, so the apiserver reaches pods/metrics-server directly. Removes the konnectivity
    # SPOF. konnectivity-server is disabled via --disable-components on the k0scontroller ExecStart.
    # See docs/RUNBOOK-konnectivity-direct-egress.md.
    extraArgs:
      egress-selector-config-file: /etc/k0s/egress-direct.yaml
    sans:
    - {{internal_ip}}
    # HA control-plane VIP — k0s worker bootstrap (incl. cluster-autoscaler nodes) validates TLS
    # against this address, so it must be in the serving cert. See RUNBOOK-node-autoscaling.md.
    - 10.0.0.240
    ca:
      expiresAfter: 87600h
      certificatesExpireAfter: 8760h
  controllerManager: {}
  extensions:
    helm:
      concurrencyLevel: 5
  installConfig:
    users:
      etcdUser: etcd
      kineUser: kube-apiserver
      konnectivityUser: konnectivity-server
      kubeAPIserverUser: kube-apiserver
      kubeSchedulerUser: kube-scheduler
  konnectivity:
    adminPort: 8133
    agentPort: 8132
  network:
    clusterDomain: cluster.local
    dualStack:
      enabled: false
    kubeProxy:
      iptables:
        minSyncPeriod: 0s
        syncPeriod: 0s
      ipvs:
        minSyncPeriod: 0s
        syncPeriod: 0s
        tcpFinTimeout: 0s
        tcpTimeout: 0s
        udpTimeout: 0s
      metricsBindAddress: 0.0.0.0:10249
      mode: iptables
    # Calico (VXLAN) replaces kube-router. Reason: kube-router on Hetzner's
    # anti-spoofing private network dropped pod->node-IP traffic (pod->apiserver,
    # pod->DB) and kept degrading after restarts. Calico's IP pool natOutgoing
    # (default) masquerades pod egress to node IPs correctly.
    # MTU: Hetzner link 1450 - 50B VXLAN = 1400. ipAutodetection pins the private nic.
    # NLLB (Envoy) dropped — Calico fixes the pod->node path NLLB worked around.
    calico:
      mode: vxlan
      overlay: Always
      vxlanPort: 4789
      vxlanVNI: 4096
      mtu: 1400
      wireguard: false
      # MUST be the whole private network (/16), not the static /24 subnet: cluster-autoscaler nodes
      # live in 10.0.1.0/24, and a /24-scoped autodetection makes calico-node on those nodes fail to
      # find the private IP -> crashloop -> node wedges. See RUNBOOK-node-autoscaling.md.
      ipAutodetectionMethod: cidr=10.0.0.0/16
    podCIDR: 10.244.0.0/16
    provider: calico
    serviceCIDR: 10.96.0.0/12
  scheduler: {}
  storage:
    etcd:
      peerAddress: {{internal_ip}}
      ca:
        expiresAfter: 87600h
        certificatesExpireAfter: 8760h
    type: etcd
  telemetry:
    enabled: true
